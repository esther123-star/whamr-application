# ─── Cloudflare R2 Credentials ───────────────────────────────────────────────
# Copy this file to .env.r2 and fill in your values.
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
#
# Step-by-step:
#   1. Go to dash.cloudflare.com → R2 Object Storage
#   2. Create a bucket (e.g. "whamr-media")
#   3. In bucket Settings → enable "Allow Public Access" → copy the public URL
#   4. Go to R2 → Manage R2 API Tokens → Create API Token
#      Permissions: Object Read & Write  |  Scope: your bucket
#   5. Copy Account ID from the R2 overview page (top right)

R2_ACCOUNT_ID=your_account_id_here
R2_ACCESS_KEY_ID=your_access_key_id_here
R2_SECRET_ACCESS_KEY=your_secret_access_key_here
R2_BUCKET_NAME=whamr-media
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# ─── Local media source ───────────────────────────────────────────────────────
# Absolute path to the "Memes & Stickers" folder on your machine
MEDIA_SOURCE=C:\Users\EliteBook 1030G3\Videos\Sticker-Ninja\Memes & Stickers
